---
import { profile } from '../data/profile';
---

<section id="about" class="section about">
  <div class="container">
    <div class="about-grid">
      <div class="about-head" data-reveal>
        <p class="kicker mono">// 01 — about</p>
        <h2 class="section-title">Building AI that holds up in production.</h2>
      </div>

      <div class="about-body" data-reveal style="--reveal-delay: 120ms">
        {profile.about.map((para) => <p class="about-p">{para}</p>)}
      </div>
    </div>

    <ul class="stats">
      {
        profile.stats.map((stat, i) => (
          <li class="stat card" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <span class="stat-value mono">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .about-p {
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .about-p + .about-p {
    margin-top: 1.1rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .stat {
    padding: 1.5rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-value {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    color: var(--accent-bright);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.86rem;
    color: var(--text-dim);
    line-height: 1.4;
  }

  @media (max-width: 880px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
